#!/usr/bin/env bash
set -euo pipefail

# MikoCode settings TUI.
# Runs standalone (`mikocode --settings`) or inside a centered tmux popup (Ctrl-a S).
# Saves to ~/.config/mikocode/config and applies tmux theme changes live.

CONFIG_DIR="$HOME/.config/mikocode"
CONFIG_FILE="$CONFIG_DIR/config"
THEME_FILE="$CONFIG_DIR/theme.tmux.conf"

HAVE_GUM=0
command -v gum >/dev/null 2>&1 && [[ -t 0 && -t 1 ]] && HAVE_GUM=1

# Defaults (must match bin/mikocode)
MIKOCODE_THEME="purple"
MIKOCODE_ACCENT="colour99"
MIKOCODE_STATUS_POSITION="bottom"
MIKOCODE_MOUSE="on"
MIKOCODE_EDITOR="nvim"
MIKOCODE_AI="opencode"
MIKOCODE_NVIM_THEME="tokyonight-night"
MIKOCODE_FOCUS="editor"
MIKOCODE_START_MODE="normal"
MIKOCODE_AI_WIDTH="30"
MIKOCODE_SHELL_HEIGHT="25"
MIKOCODE_TIPS="on"

KEYS=(THEME ACCENT STATUS_POSITION MOUSE EDITOR AI NVIM_THEME FOCUS START_MODE AI_WIDTH SHELL_HEIGHT TIPS)

load_config() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  local key val
  while IFS='=' read -r key val; do
    [[ "$key" =~ ^MIKOCODE_[A-Z_]+$ ]] || continue
    val="${val#\"}"
    val="${val%\"}"
    printf -v "$key" '%s' "$val"
  done < "$CONFIG_FILE"
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  {
    echo "# MikoCode settings. Managed by 'mikocode --settings' (Ctrl-a S in tmux)."
    echo "# Env vars with the same names override these per invocation."
    local k var
    for k in "${KEYS[@]}"; do
      var="MIKOCODE_$k"
      printf '%s="%s"\n' "$var" "${!var}"
    done
  } > "$CONFIG_FILE"
}

accent_for_theme() {
  case "$1" in
    purple) echo "colour99" ;;
    blue)   echo "colour39" ;;
    green)  echo "colour42" ;;
    red)    echo "colour203" ;;
    orange) echo "colour208" ;;
    pink)   echo "colour212" ;;
    teal)   echo "colour44" ;;
    custom) echo "$MIKOCODE_ACCENT" ;;
    *)      echo "colour99" ;;
  esac
}

write_theme_file() {
  local accent
  accent="$(accent_for_theme "$MIKOCODE_THEME")"
  mkdir -p "$CONFIG_DIR"
  cat > "$THEME_FILE" <<THEME
# Generated by 'mikocode --settings'. Do not edit by hand; edit via Ctrl-a S.
set -g status-position $MIKOCODE_STATUS_POSITION
set -g mouse $MIKOCODE_MOUSE
set -g pane-active-border-style fg=$accent
set -g popup-border-lines rounded
set -g popup-border-style fg=$accent
set -g window-status-format " #[fg=colour250]#W#{?window_end_flag, #[fg=$accent,bold]+,} "
set -g window-status-current-format " #[bg=$accent,fg=white,bold] #W #[default]#{?window_end_flag,#[fg=$accent,bold]+#[default],} "
set -g status-left "#[fg=$accent,bold] MikoCode #[fg=colour240]│ "
THEME
}

apply() {
  save_config
  write_theme_file
  if [[ -n "${TMUX:-}" ]] || tmux ls >/dev/null 2>&1; then
    tmux source-file "$HOME/.tmux.conf" 2>/dev/null || true
  fi
}

choose() {
  local header="$1"
  shift
  local opts=("$@")
  if [[ "$HAVE_GUM" == "1" ]]; then
    gum choose --header "$header" --height 16 "${opts[@]}" || true
    return 0
  fi
  echo >&2
  echo "$header" >&2
  local i=1 opt
  for opt in "${opts[@]}"; do
    printf '%2d) %s\n' "$i" "$opt" >&2
    i=$((i + 1))
  done
  local n
  while :; do
    printf 'Choice [1-%d, empty to cancel]: ' "${#opts[@]}" >&2
    read -r n || return 0
    [[ -z "$n" ]] && return 0
    if [[ "$n" =~ ^[0-9]+$ ]] && ((n >= 1 && n <= ${#opts[@]})); then
      printf '%s' "${opts[n - 1]}"
      return 0
    fi
  done
}

input() {
  local header="$1" current="$2" value
  if [[ "$HAVE_GUM" == "1" ]]; then
    value="$(gum input --header "$header" --value "$current" || true)"
  else
    printf '%s [%s]: ' "$header" "$current" >&2
    read -r value || true
  fi
  [[ -z "$value" ]] && value="$current"
  printf '%s' "$value"
}

input_percent() {
  local header="$1" current="$2" value
  while :; do
    value="$(input "$header (10-80)" "$current")"
    if [[ "$value" =~ ^[0-9]+$ ]] && ((value >= 10 && value <= 80)); then
      printf '%s' "$value"
      return 0
    fi
    echo "Enter a number between 10 and 80." >&2
  done
}

pick_theme() {
  local sel
  sel="$(choose "Accent theme (colors the tmux status bar, borders, popups)" \
    purple blue green red orange pink teal custom)"
  [[ -z "$sel" ]] && return 0
  MIKOCODE_THEME="$sel"
  if [[ "$sel" == "custom" ]]; then
    MIKOCODE_ACCENT="$(input "Custom tmux color (e.g. colour99, #d787ff)" "$MIKOCODE_ACCENT")"
  fi
}

pick_editor() {
  local sel
  sel="$(choose "Editor shown in the main pane" \
    "nvim" "vim" "hx (Helix)" "micro" "emacs -nw" "custom command")"
  [[ -z "$sel" ]] && return 0
  case "$sel" in
    "hx (Helix)") MIKOCODE_EDITOR="hx" ;;
    "custom command") MIKOCODE_EDITOR="$(input "Editor command" "$MIKOCODE_EDITOR")" ;;
    *) MIKOCODE_EDITOR="$sel" ;;
  esac
}

pick_ai() {
  local sel
  sel="$(choose "AI assistant shown in the right pane" \
    "opencode" "claude" "codex" "gemini" "aider" "none (plain shell)" "custom command")"
  [[ -z "$sel" ]] && return 0
  case "$sel" in
    "none (plain shell)") MIKOCODE_AI="none" ;;
    "custom command") MIKOCODE_AI="$(input "AI command" "$MIKOCODE_AI")" ;;
    *) MIKOCODE_AI="$sel" ;;
  esac
}

pick_nvim_theme() {
  local sel
  sel="$(choose "Neovim colorscheme (applies to new editor panes)" \
    tokyonight-night tokyonight-storm tokyonight-moon tokyonight-day \
    catppuccin-mocha catppuccin-macchiato catppuccin-frappe catppuccin-latte \
    gruvbox kanagawa custom)"
  [[ -z "$sel" ]] && return 0
  if [[ "$sel" == "custom" ]]; then
    MIKOCODE_NVIM_THEME="$(input "Colorscheme name" "$MIKOCODE_NVIM_THEME")"
  else
    MIKOCODE_NVIM_THEME="$sel"
  fi
}

pick_simple() {
  # pick_simple VAR "header" opt...
  local var="$1" header="$2" sel
  shift 2
  sel="$(choose "$header" "$@")"
  [[ -z "$sel" ]] && return 0
  printf -v "$var" '%s' "$sel"
}

reset_defaults() {
  MIKOCODE_THEME="purple"
  MIKOCODE_ACCENT="colour99"
  MIKOCODE_STATUS_POSITION="bottom"
  MIKOCODE_MOUSE="on"
  MIKOCODE_EDITOR="nvim"
  MIKOCODE_AI="opencode"
  MIKOCODE_NVIM_THEME="tokyonight-night"
  MIKOCODE_FOCUS="editor"
  MIKOCODE_START_MODE="normal"
  MIKOCODE_AI_WIDTH="30"
  MIKOCODE_SHELL_HEIGHT="25"
  MIKOCODE_TIPS="on"
}

header_banner() {
  if [[ "$HAVE_GUM" == "1" ]]; then
    gum style --bold --foreground 212 "MikoCode Settings"
    gum style --faint "Changes save and apply immediately. Pane layout applies to new workspaces."
  else
    echo "MikoCode Settings"
    echo "Changes save and apply immediately. Pane layout applies to new workspaces."
  fi
}

load_config

while :; do
  clear 2>/dev/null || true
  header_banner
  echo
  sel="$(choose "Pick a setting" \
    "Accent theme        [$MIKOCODE_THEME]" \
    "Editor              [$MIKOCODE_EDITOR]" \
    "AI assistant        [$MIKOCODE_AI]" \
    "Neovim colorscheme  [$MIKOCODE_NVIM_THEME]" \
    "Status bar position [$MIKOCODE_STATUS_POSITION]" \
    "Mouse support       [$MIKOCODE_MOUSE]" \
    "Focus pane on open  [$MIKOCODE_FOCUS]" \
    "Editor start mode   [$MIKOCODE_START_MODE]" \
    "AI pane width       [$MIKOCODE_AI_WIDTH%]" \
    "Shell pane height   [$MIKOCODE_SHELL_HEIGHT%]" \
    "Shell pane tips     [$MIKOCODE_TIPS]" \
    "Reset to defaults" \
    "Done")"

  case "$sel" in
    "Accent theme"*) pick_theme ;;
    "Editor      "*) pick_editor ;;
    "AI assistant"*) pick_ai ;;
    "Neovim colorscheme"*) pick_nvim_theme ;;
    "Status bar position"*) pick_simple MIKOCODE_STATUS_POSITION "Status bar position" bottom top ;;
    "Mouse support"*) pick_simple MIKOCODE_MOUSE "Mouse support" on off ;;
    "Focus pane on open"*) pick_simple MIKOCODE_FOCUS "Pane focused when a workspace opens" editor shell ai ;;
    "Editor start mode"*) pick_simple MIKOCODE_START_MODE "Editor start mode (diff opens Diffview in git repos)" normal diff ;;
    "AI pane width"*) MIKOCODE_AI_WIDTH="$(input_percent "AI pane width %" "$MIKOCODE_AI_WIDTH")" ;;
    "Shell pane height"*) MIKOCODE_SHELL_HEIGHT="$(input_percent "Shell pane height %" "$MIKOCODE_SHELL_HEIGHT")" ;;
    "Shell pane tips"*) pick_simple MIKOCODE_TIPS "Show keybinding tips in the shell pane" on off ;;
    "Reset to defaults") reset_defaults ;;
    "Done"|"") apply; break ;;
  esac

  apply
done

echo "Saved to $CONFIG_FILE"
